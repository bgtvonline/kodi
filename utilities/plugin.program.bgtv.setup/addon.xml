<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.bgtv.setup" name="[COLOR red]BGTV[/COLOR] Съветник за Настройка" version="1.0.1" provider-name="BGTV">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="pvr.hts" version="0.0.0" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="bg">Бърза настройка на BGTV (Live TV)</summary>
        <summary lang="en">1-Click BGTV Live TV Setup</summary>
        <description lang="bg">Този инструмент автоматично инсталира и настройва TVHeadend PVR добавката. Той ще попълни всички нужни портове и адреси за сървъра на BGTV (bgtv.pw), след което ще ви попита само за вашето потребителско име и парола.</description>
        <platform>all</platform>
    </extension>
</addon>
