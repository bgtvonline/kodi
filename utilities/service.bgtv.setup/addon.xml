<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.bgtv.setup"
       name="[COLOR red]BGTV[/COLOR] Съветник за Настройка"
       version="3.1.0"
       provider-name="BGTV">

  <requires>
    <import addon="xbmc.python" version="3.1.0"/>
  </requires>

  <!-- Auto-run at Kodi startup -->
  <extension point="xbmc.service" library="service.py" start="startup" />

  <extension point="xbmc.addon.metadata">
    <summary lang="bg">Бърза настройка на BGTV (Live TV)</summary>
    <summary lang="en">1-Click BGTV Live TV Setup</summary>

    <description lang="bg">
      Този инструмент автоматично инсталира и настройва TVHeadend PVR клиента за BGTV (bgtv.pw).
      Въведете потребителско име и парола, след което Kodi ще се рестартира.
    </description>
    <description lang="en">
      Installs and configures the TVHeadend PVR client for BGTV (bgtv.pw). Enter username/password then Kodi restarts.
    </description>

    <platform>all</platform>
    <license>MIT</license>
  </extension>

</addon>