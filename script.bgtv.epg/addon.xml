<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.bgtv.epg"
       name="[COLOR red]BGTV[/COLOR] Channel Logos"
       version="1.0.0"
       provider-name="BGTV">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="bg">Инсталира логата на BGTV каналите</summary>
    <summary lang="en">Installs BGTV channel logos/picons</summary>

    <description lang="bg">
      Изтегля 500+ лога на канали от BGTV сървъра.
      TV справочникът ще показва красиви икони до всеки канал.
    </description>
    <description lang="en">
      Downloads 500+ channel logos from BGTV server.
      Your TV Guide will show beautiful icons for every channel.
    </description>

    <platform>all</platform>
    <license>MIT</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>

</addon>
