<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.bgpvr"
       name="BGPVR Add-on Repository"
       version="1.0.0"
       provider-name="BGPVR">

  <extension point="xbmc.addon.repository" name="BGPVR Add-on Repository">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/bgtvonline/kodi/main/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/bgtvonline/kodi/main/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/bgtvonline/kodi/main</datadir>
    </dir>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en">Official BGPVR Kodi Repository</summary>
    <description lang="en">
      Provides BGPVR Setup, BGPVR Live TV, and the Buffering Fix addon.
      Works with any BGPVR server — enter your URL, username and password.
    </description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>

</addon>
