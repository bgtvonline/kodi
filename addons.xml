<addons>
    <addon id="repository.bgtv" name="[COLOR red][B]BGTV[/B][/COLOR] Add-on Repository" version="1.0.1" provider-name="BGTV">
        <extension point="xbmc.addon.repository" name="[COLOR red][B]BGTV[/B][/COLOR] Add-on Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/bgtvonline/kodi/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/bgtvonline/kodi/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/bgtvonline/kodi/main</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>BGTV Custom Kodi Repository</summary>
            <description>The official repository for BGTV members. Provides safe and curated add-ons including the OpenWizard buffering fix, Seren, The Crew, and The Loop.</description>
            <disclaimer>This repository acts as a directory to original author packages.</disclaimer>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>
    <addon id="plugin.program.bgtv.setup" name="[COLOR red]BGTV[/COLOR] Съветник за Настройка" version="1.0.9" provider-name="BGTV">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="pvr.hts" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <import addon="pvr.hts" />
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="bg">Бърза настройка на BGTV (Live TV)</summary>
            <summary lang="en">1-Click BGTV Live TV Setup</summary>
            <description lang="bg">Този инструмент автоматично настройва TVHeadend PVR добавката за BGTV (bgtv.pw). Просто въведете вашето потребителско име и парола.</description>
            <platform>all</platform>
        </extension>
    </addon>
