<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.bgtv"
       name="[COLOR red]BGTV[/COLOR] Live TV"
       version="1.0.0"
       provider-name="BGTV">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="bg">Гледайте BGTV канали директно</summary>
    <summary lang="en">Watch BGTV channels directly</summary>

    <description lang="bg">
      Гледайте BGTV канали без PVR настройка.
      Просто въведете потребителско име и парола.
    </description>
    <description lang="en">
      Watch BGTV channels without PVR setup.
      Just enter your username and password.
    </description>

    <platform>all</platform>
    <license>MIT</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>

</addon>
